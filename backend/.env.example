# Environment Configuration
# Copy this to .env and fill in your values.

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Primary model (Groq). Fallbacks are configured in app/core/config.py.
LLM_MODEL=llama-3.3-70b-versatile

# Any long random string — signs JWTs.
JWT_SECRET=change-me-to-a-random-string

# PlantUML rendering server (Docker sidecar).
PLANTUML_SERVER_URL=http://localhost:8090

# SQLite (file-based, created by the initial Alembic migration / on first startup).
DATABASE_URL=sqlite+aiosqlite:///./uml_chatbot.db

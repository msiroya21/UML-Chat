{
  "type": "object",
  "title": "SequenceDiagramIR",
  "required": ["diagram_type", "title", "participants", "messages"],
  "properties": {
    "diagram_type": { "type": "string", "const": "sequence" },
    "title": { "type": "string" },
    "participants": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "properties": {
          "id":    { "type": "string", "description": "Unique identifier, e.g. 'user', 'db', 'auth_svc'" },
          "label": { "type": "string", "description": "Display name" },
          "type":  { "type": "string", "enum": ["actor", "component", "database", "boundary", "control", "entity", "collections", "queue"] }
        }
      }
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "label", "type", "order"],
        "properties": {
          "from":  { "type": "string", "description": "Sender participant id" },
          "to":    { "type": "string", "description": "Receiver participant id" },
          "label": { "type": "string" },
          "type":  { "type": "string", "enum": ["sync", "async", "return"] },
          "order": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
